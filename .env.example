# Required by both Flask services and Hindsight.
OPENAI_API_KEY=sk-your-openai-api-key

# Optional. Enables medical_qa and feedback QA uploads to the same vector store.
OPENAI_MED_QA_VECTOR_STORE_ID=vs_your-vector-store-id

# Optional model overrides.
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_EMOTION_MODEL=gpt-5.4-mini
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
HINDSIGHT_LLM_MODEL=gpt-5.4-mini

# Optional Hindsight settings used by server_realtime.py.
HINDSIGHT_ENABLED=true
HINDSIGHT_BASE_URL=http://127.0.0.1:8888
HINDSIGHT_TIMEOUT_SECONDS=5
HINDSIGHT_RECALL_TIMEOUT_SECONDS=5
HINDSIGHT_RECALL_MAX_TOKENS=1200
HINDSIGHT_RECALL_BUDGET=low

# Optional SQLite path, relative to the project root or absolute.
APP_DB_PATH=data/app_data.sqlite3
